## Runtime mode
# STAGING | PROD
APP_ENV=STAGING
NODE_ENV=development

## Ports
# Local fallback port
PORT=5000
# Optional explicit split by environment
PORT_DEV=5000
PORT_STAGING=5000
PORT_PROD=8080

## Database URIs
# Backward-compatible single URI (optional)
MONGO_URI=
# Preferred split URIs
MONGO_URI_DEV=mongodb+srv://<dev_user>:<dev_password>@<cluster>/<dev_db>
MONGO_URI_STAGING=mongodb+srv://<staging_user>:<staging_password>@<cluster>/<staging_db>
MONGO_URI_PROD=mongodb+srv://<prod_user>:<prod_password>@<cluster>/<prod_db>

## CORS / Socket allowed origins
FRONTEND_URL_DEV=http://localhost:3000
FRONTEND_URL_STAGING=http://localhost:3000
FRONTEND_URL_PROD=https://your-amplify-domain.amplifyapp.com

## Ingest CSV location
# Optional explicit path (relative to backend runtime working directory or absolute path)
# Example (render/eb): INGEST_CSV_PATH=sample-customers.csv
# Legacy route only: POST /api/ingest
INGEST_CSV_PATH=

## Ingest v2 limits
# Max upload size in MB for POST /api/ingest/upload
INGEST_MAX_FILE_MB=5
